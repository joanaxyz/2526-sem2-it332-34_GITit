DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEPLOYMENT_VERSION=replace-with-commit-sha
DJANGO_LOG_LEVEL=INFO
PERFORMANCE_TIMING_ENABLED=False

DJANGO_ALLOWED_HOSTS=app.example.com,api.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com
CORS_ALLOW_CREDENTIALS=True

DATABASE_URL=postgresql://git_it:replace-password@postgres:5432/git_it
DATABASE_CONN_MAX_AGE=60
DATABASE_CONN_HEALTH_CHECKS=True
DATABASE_DISABLE_SERVER_SIDE_CURSORS=True
DATABASE_DISABLE_PREPARED_STATEMENTS=True
DATABASE_LOCK_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=30000

REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5

# Enable only behind a known reverse proxy/load balancer. The direct peer must
# belong to one of these exact IPs or CIDR ranges before forwarded headers count.
DJANGO_TRUST_PROXY_HEADERS=True
DJANGO_TRUSTED_PROXY_IPS=172.16.0.0/12

AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_SECONDS=300
THROTTLE_AUTH_REGISTER=60/hour
THROTTLE_AUTH_REFRESH=600/hour
THROTTLE_AUTH_PASSWORD_RESET=20/hour
THROTTLE_AUTH_PASSWORD_RESET_CONFIRM=60/hour
THROTTLE_COMMAND_SUBMIT=120/min

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_COOKIE_NAME=git_it_refresh
JWT_COOKIE_PATH=/api/auth/
JWT_COOKIE_DOMAIN=.example.com
JWT_COOKIE_SAMESITE=Strict
JWT_COOKIE_SECURE=True

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=same-origin

FRONTEND_BASE_URL=https://app.example.com

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=GIT it! <no-reply@example.com>
PASSWORD_RESET_TIMEOUT=3600
API_VERSION=0.1.0

ALLOW_DESTRUCTIVE_SEED_RESET=False
