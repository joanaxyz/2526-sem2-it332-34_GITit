DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
PERFORMANCE_TIMING_ENABLED=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/git_it
#
# Supabase direct connection example:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
#
# Supabase Transaction Pooler is recommended when the runtime is on an IPv4-only
# network or session limits are tight. Use port 6543 and keep sslmode=require.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite:///db.sqlite3
# Reuse connections during local dev to avoid per-request SQLite connect overhead.
DATABASE_CONN_MAX_AGE=60
DATABASE_CONN_HEALTH_CHECKS=False
DATABASE_DISABLE_SERVER_SIDE_CURSORS=True
DATABASE_DISABLE_PREPARED_STATEMENTS=True

# Local development may leave this blank to use Django's process-local
# LocMemCache. Production (DJANGO_DEBUG=False) requires Redis for shared
# refresh-token revocation across workers.
REDIS_URL=redis://localhost:6379/0
JWT_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
