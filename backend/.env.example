DJANGO_DEBUG=True
DJANGO_SECRET_KEY=dev-local-change-before-production
DEPLOYMENT_VERSION=development
DJANGO_LOG_LEVEL=INFO
PERFORMANCE_TIMING_ENABLED=True

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True

DATABASE_URL=sqlite:///db.sqlite3
DATABASE_CONN_MAX_AGE=0
DATABASE_CONN_HEALTH_CHECKS=False
SQLITE_TIMEOUT_SECONDS=20
DATABASE_DISABLE_SERVER_SIDE_CURSORS=True
DATABASE_DISABLE_PREPARED_STATEMENTS=True
DATABASE_LOCK_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=30000

# Leave blank locally unless Redis is running.
REDIS_URL=
REDIS_SOCKET_CONNECT_TIMEOUT=0.5
REDIS_SOCKET_TIMEOUT=0.5

DJANGO_TRUST_PROXY_HEADERS=False
DJANGO_TRUSTED_PROXY_IPS=

AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_SECONDS=300
THROTTLE_AUTH_REGISTER=60/hour
THROTTLE_AUTH_REFRESH=600/hour
THROTTLE_AUTH_PASSWORD_RESET=20/hour
THROTTLE_AUTH_PASSWORD_RESET_CONFIRM=60/hour
THROTTLE_COMMAND_SUBMIT=120/min

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_COOKIE_NAME=git_it_refresh
JWT_COOKIE_PATH=/api/auth/
JWT_COOKIE_DOMAIN=
JWT_COOKIE_SAMESITE=Strict
JWT_COOKIE_SECURE=False

SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=same-origin

FRONTEND_BASE_URL=http://localhost:5173

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=GIT it! <no-reply@example.com>
PASSWORD_RESET_TIMEOUT=3600
API_VERSION=0.1.0

# Never enable this during ordinary development or deployment.
ALLOW_DESTRUCTIVE_SEED_RESET=False
